{
  "root": true,
  "env": {
    "node": true,
    "es2020": true,
    "mocha": true
  },
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "project": "./tsconfig.json",
    "sourceType": "module"
  },
  "plugins": [
    "@typescript-eslint"
  ],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "ignorePatterns": [
    "out",
    "node_modules"
  ],
  "rules": {
    "@typescript-eslint/no-explicit-any": "error"
  }
}
